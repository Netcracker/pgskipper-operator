#!/bin/sh -e

read_secret() {
  local path="$1"

  if [ -f "$path" ]; then
    cat "$path"
  fi
}

POSTGRES_USER="$(read_secret /var/run/secrets/postgres/postgres-credentials/username)"
POSTGRES_PASSWORD="$(read_secret /var/run/secrets/postgres/postgres-credentials/password)"

POSTGRES_USER="${POSTGRES_USER}" POSTGRES_PASSWORD="${POSTGRES_PASSWORD}" exec ${EXPORTER_FILE} $@